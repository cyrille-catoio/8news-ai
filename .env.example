# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Full descriptions: SPEC.md § Environment Variables

# --- Core (required for most features) ---
OPENAI_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ELEVENLABS_API_KEY=
TRANSCRIPT_API_KEY=

# Bearer secret for cron-triggered routes (fetch-feeds, test-score, summaries/generate, roundups/generate, Netlify cron functions)
CRON_SECRET=

# --- Optional ---
# YouTube Data API v3 — backfills video duration / Shorts filter; omit for local smoke tests that skip video tooling
# YOUTUBE_API_KEY=

# --- Netlify background tuning (defaults usually fine; only set in production if needed) ---
# CRON_BACKGROUND_FETCH_BUDGET_MS=
# CRON_BACKGROUND_SAFETY_RESERVE_MS=
# FETCH_STALE_THRESHOLD_MS=
# CRON_BACKGROUND_SCORE_BUDGET_MS=
# SCORE_MAX_ARTICLES_PER_RUN=
# SCORE_MIN_ARTICLES_PER_RUN=
# SCORE_HARD_ARTICLE_CAP=
# TRANSCRIBE_BUDGET_MS=
# TRANSCRIBE_MAX_PER_RUN=

# --- Video recap quality cron (cron-video-summary-score-background) — optional tuning ---
# VIDEO_SUMMARY_SCORE_MODEL=gpt-4.1-mini
# VIDEO_SUMMARY_SCORE_BATCH_SIZE=8
# VIDEO_SUMMARY_SCORE_BATCH_CAP=12
# VIDEO_SUMMARY_SCORE_MAX_CHARS=3500
# VIDEO_SUMMARY_SCORE_OPENAI_TIMEOUT_MS=20000
# CRON_VIDEO_SUMMARY_SCORE_BUDGET_MS=810000
# CRON_VIDEO_SUMMARY_SCORE_SAFETY_MS=45000

# --- Daily newsletter cron (cron-newsletter-daily-background) — v2.6.12+ ---
# Resend API key for sending the daily Top 24h newsletter. Required.
# Get one at https://resend.com/api-keys
# RESEND_API_KEY=
# « From » address used on the newsletter envelope. The domain must be
# verified in your Resend account. Format: « Display name <local@domain> ».
# Default falls back to "8news <newsletter@8news.ai>".
# RESEND_FROM_ADDRESS=
# Optional mailto for the List-Unsubscribe header (RFC 8058). Defaults
# to "unsubscribe@8news.ai".
# NEWSLETTER_UNSUBSCRIBE_MAILTO=
# Optional override for the absolute origin used to build « Read the
# full archive » links inside the email body. Defaults to "https://8news.ai".
# NEWSLETTER_PUBLIC_ORIGIN=
